<!DOCTYPE html>
<html>
<head>
<meta charset="ISO-8859-1">
<title>Add</title>
</head>

<body>
    <div class="container">
    <h1>Add New Employee</h1>
    <p>Please fill in this form to create a employee entry.</p>
    <hr>
        <div>
            <div>
                <form action="#" th:action="@{/addemployee}" th:object="${employee}" method="post">
                    <div class="row">
                        <div >
                            <label for="name"><b>Name</b></label>
                            <input type="text" th:field="*{name}" id="name" placeholder="Please enter your Name">
                                <span th:if="${#fields.hasErrors('name')}" th:errors="*{name}" ></span>
                            </div>
                            <div >
                                <label for="surname"><b>Surname</b></label>
                                <input type="text" th:field="*{surname}" id="surname" placeholder="Please enter your Surname">
                                    <span th:if="${#fields.hasErrors('surname')}" th:errors="*{surname}" ></span>
                                </div>
                                <div >
                                    <label for="email"><b>Email</b></label>
                                    <input type="text" th:field="*{email}" id="email" placeholder="Please enter your Email">
                                        <span th:if="${#fields.hasErrors('email')}" th:errors="*{email}" ></span>
                                    </div>
                                </div>
                                <div class="row">
                                    <div >
                                        <input type="submit" value="Add Employee">
                                        </div>
                                    </div>
                    </form>
                </div>
            </div>
        </div>
</body>

</html>